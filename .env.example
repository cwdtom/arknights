# Required: planner and ReAct model calls.
DEEPSEEK_API_KEY=

# Required: Feishu/Lark websocket bot credentials and default reply target.
LARK_APP_ID=
LARK_APP_SECRET=
LARK_USER_OPEN_ID=

# Optional: internet_search requires this when invoked.
BOCHA_API_KEY=

# Optional: SQLite database path, defaults to arknights.db in code.
ARKNIGHTS_DB_PATH=arknights.db

# Optional: enable async chat-history embedding and vector search when set.
# Supported values:
# BAAI/bge-small-en-v1.5
# BAAI/bge-small-zh-v1.5
ARKNIGHTS_RAG_MODEL=

# Optional high-risk switch: enables system_bash and gives the agent read/write
# access to all files the service process can access. Leave false to disable.
BASH_TOOL_ENABLE=false
